# conscio — environment configuration
# Copy this to .env and fill in your credentials.

# LibertAI (or any OpenAI-compatible backend)
LIBERTAI_API_KEY=your_api_key_here
LIBERTAI_BASE_URL=https://api.libertai.io/v1
LIBERTAI_MODEL=qwen3.6-35b-a3b

# OpenAI-compatible backend (alternative to LIBERTAI_*)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
