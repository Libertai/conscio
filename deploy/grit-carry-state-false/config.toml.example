[service]
home = "/home/conscio/.conscio"
host = "127.0.0.1"
port = 8765
client_url = "https://grit-carry-state-false.2n6.me"
api_key = "replace-with-generated-api-key"
web_password = "replace-with-generated-web-password"
web_secure_cookies = true
allow_insecure_public_bind = false
autonomous = true
tick_interval = 30
unsafe_autonomy = false
pause_on_error = true

[llm]
base_url = ""
api_key = ""
model = "deepseek-v4-flash"

[context]
recent_episodes = 3
retrieved_memories = 5
workspace_entries = 12
max_dynamic_chars = 12000
compaction_interval = 20
enable_semantic_compaction = true

[tools]
allowed = []
denied = []
max_actions_per_hour = 60
shell_timeout = 30
working_directory = "/opt/conscio/work"
